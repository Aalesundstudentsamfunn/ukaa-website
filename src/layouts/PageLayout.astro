---
import SiteMeta from "../components/SiteMeta.astro";
import Navigation from "../components/Navigation.astro";
import "../assets/styles/global.css";

const {
  title = "U.-KA.",
  description = "U.-KA. er Ålesunds studentfestival med konserter, show, foredrag og sosiale arrangementer gjennom uka.",
} = Astro.props;
---

<html lang="nb" data-theme="cerberus">
  <head>
    <SiteMeta title={title} description={description} />
  </head>
  <body class="text-neutral-900">
    <a href="#main-content" class="skip-link">Hopp til innhold</a>
    <Navigation />
    <main id="main-content" class="relative isolate min-h-svh flex flex-col">
      <slot />
    </main>
  </body>
</html>

<script>
  (() => {
    const CHUNK_RELOAD_KEY = "ukaa:chunk-reload-ts";
    const CHUNK_RELOAD_TTL_MS = 5 * 60 * 1000;
    const CHUNK_URL_PATTERN = /\/_astro\/[^\s'"]+\.js\b/i;
    const CHUNK_ERROR_PATTERN =
      /(Failed to fetch dynamically imported module|Importing a module script failed|Loading chunk|ChunkLoadError)/i;

    const isChunkLoadError = (...parts) => {
      const joined = parts.filter(Boolean).map((p) => String(p)).join(" ");
      if (!joined) return false;

      // Most reliable signal: hashed Astro JS chunk path present.
      if (CHUNK_URL_PATTERN.test(joined)) return true;

      // Fallback: generic chunk words only count if the error also references Astro assets.
      return CHUNK_ERROR_PATTERN.test(joined) && joined.includes("/_astro/");
    };

    const tryReloadOnce = () => {
      const now = Date.now();
      const last = Number(sessionStorage.getItem(CHUNK_RELOAD_KEY) || "0");
      if (last && now - last < CHUNK_RELOAD_TTL_MS) return;
      sessionStorage.setItem(CHUNK_RELOAD_KEY, String(now));
      window.location.reload();
    };

    window.addEventListener("vite:preloadError", (event) => {
      event.preventDefault();
      tryReloadOnce();
    });

    window.addEventListener("error", (event) => {
      const message = String(event?.message || "");
      const source = String(event?.filename || "");
      const stack = String(event?.error?.stack || "");
      if (!isChunkLoadError(message, source, stack)) return;
      event.preventDefault?.();
      tryReloadOnce();
    });

    window.addEventListener("unhandledrejection", (event) => {
      const reason = event?.reason;
      const message =
        typeof reason === "string"
          ? reason
          : String(reason?.message || reason || "");
      const stack = String(reason?.stack || "");
      if (!isChunkLoadError(message, stack)) return;
      event.preventDefault?.();
      tryReloadOnce();
    });

    if ("serviceWorker" in navigator) {
      navigator.serviceWorker.register("/sw.js").catch(() => {});
    }
  })();
</script>
