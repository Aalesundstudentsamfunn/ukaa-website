---
interface Props {
  title?: string;
  description?: string;
  author?: string;
  themeColor?: string;
}

const {
  title = "U.-KA.",
  description = "U.-KA. er en energisk og fargerik studentfestival i Ålesund arrangert av Ålesund Studentsamfunn, med konserter, show, foredrag og sosiale arrangementer gjennom hele uka.",
  author = "Dennis Løvold",
  themeColor = "#fdbc5b",
} = Astro.props as Props;

const siteName = "U.-KA.";

// Normalize + decide how the full title should look
const rawTitle = title || siteName;
const isHome = rawTitle === siteName;

// Browser tab title
const fullTitle = isHome ? `${siteName} / Ålesund` : `${siteName} / ${rawTitle}`;

// OG/Twitter titles
const socialTitle = isHome ? `${siteName} / Ålesund` : `${siteName} / ${rawTitle}`;

// Always use the same OG image
const ogImage = "/og-image.png";

// Absolute URL for OG/Twitter
const pageUrl = Astro.url.href;
const ogImageUrl = Astro.site
  ? new URL(ogImage, Astro.site).toString()
  : ogImage;
---

<!-- Primary Meta -->
<meta charset="utf-8" />
<meta
  name="viewport"
  content="width=device-width, height=device-height, initial-scale=1, viewport-fit=cover"
/>
<title>{fullTitle}</title>
<meta name="description" content={description} />
<meta name="author" content={author} />

<!-- Canonical -->
<link rel="canonical" href={pageUrl} />

<!-- Theme colors -->
<meta name="theme-color" content={themeColor} />

<!-- Preconnect to external resources -->
<link rel="preconnect" href="https://res.cloudinary.com" />
<link rel="dns-prefetch" href="https://res.cloudinary.com" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

<!-- Apple mobile -->
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black" />

<!-- Favicons -->
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="icon" href="/icons/icon-32.png" sizes="32x32" type="image/png" />
<link rel="shortcut icon" href="/icons/icon-32.png" type="image/png" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:site_name" content={siteName} />
<meta property="og:locale" content="nb_NO" />
<meta property="og:title" content={socialTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={pageUrl} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={socialTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />

<!-- JSON-LD Structured Data -->
<script is:inline type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "U.-KA. 2026",
  "description": description,
  "startDate": "2026-03-12",
  "endDate": "2026-03-22",
  "eventStatus": "https://schema.org/EventScheduled",
  "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
  "location": {
    "@type": "Place",
    "name": "Ålesund",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Ålesund",
      "addressCountry": "NO"
    }
  },
  "organizer": {
    "@type": "Organization",
    "name": "Ålesund Studentsamfunn",
    "url": "https://ukaa.no"
  },
  "image": ogImageUrl,
  "url": "https://ukaa.no",
  "offers": {
    "@type": "Offer",
    "url": "https://tikkio.com/organizer/2624-ass-alesund-studentsamfunn",
    "availability": "https://schema.org/InStock"
  }
})} />
