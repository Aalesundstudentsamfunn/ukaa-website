---
import { CldImage } from "astro-cloudinary";

type GalleryItem = string | { src: string; alt?: string; caption?: string };

export interface Props {
  id: string;
  title: string;
  tag?: string;
  blurb?: string;
  gallery?: GalleryItem[];
  accent: string;
}

const { id, title, tag, blurb, gallery = [], accent } = Astro.props as Props;

const galleryItems = gallery.map((g) => {
  if (typeof g === "string") {
    return { src: g.trim(), alt: undefined, caption: undefined };
  }
  return {
    ...g,
    src: String(g.src || "").trim(),
  };
});

const headingId = `${id}-title`;
---

<dialog id={id} class="modal" aria-labelledby={headingId} tabindex="-1">
  <div class="modal-container fixed inset-0 grid place-items-center p-4 sm:p-6">
    <div class="modal-panel relative grid max-h-[90vh] w-full max-w-4xl grid-rows-[auto,auto,1fr,auto] overflow-hidden rounded-2xl bg-white shadow-2xl ring-1 ring-black/8">

      <!-- Accent top bar -->
      <div class="h-1.5 w-full" style={`background: ${accent}`}></div>

      <!-- Header -->
      <header class="flex items-start justify-between gap-4 border-b border-neutral-100 px-5 py-4">
        <div class="min-w-0">
          {tag && (
            <div class="mb-2">
              <span
                class="inline-flex items-center rounded-full px-3 py-1 text-xs font-bold text-neutral-900 shadow-sm"
                style={`background-color: ${accent}`}
              >{tag}</span>
            </div>
          )}
          <h3 id={headingId} class="text-xl font-bold text-neutral-900 sm:text-2xl">
            {title}
          </h3>
        </div>

        <button
          type="button"
          class="shrink-0 rounded-full p-2 text-neutral-400 transition hover:bg-neutral-100 hover:text-neutral-700 focus:outline-none focus-visible:outline-none"
          aria-label="Lukk"
          data-close
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="size-5">
            <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 0 1 1.414 0L10 8.586l4.293-4.293a1 1 0 1 1 1.414 1.414L11.414 10l4.293 4.293a1 1 0 0 1-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 0 1-1.414-1.414L8.586 10 4.293 5.707a1 1 0 0 1 0-1.414Z" clip-rule="evenodd"></path>
          </svg>
        </button>
      </header>

      <!-- Body -->
      <div class="modal-body gallery-scroll px-5 pb-6 pt-5">

        {blurb && <p class="mb-5 text-neutral-700 leading-relaxed text-[0.95rem]">{blurb}</p>}

        <!-- Gallery grid (thumbnails) -->
        {galleryItems.length > 0 && (
          <div>
            <p class="mb-3 text-[0.65rem] font-bold uppercase tracking-[0.2em] text-neutral-400">Galleri</p>
            <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
              {galleryItems.map((g, i) => (
                <figure
                  class="relative aspect-4/3 overflow-hidden rounded-xl bg-neutral-100 ring-1 ring-black/5 cursor-zoom-in"
                  aria-label={g.alt || `Bilde ${i + 1} av ${title}`}
                  data-img-wrapper
                  data-gallery-index={i}
                  data-public-id={g.src}
                  data-caption={g.caption || ""}
                >
                  <div class="absolute inset-0 skeleton" />
                  <CldImage
                    draggable="false"
                    src={g.src}
                    alt={g.alt || `${title} bilde ${i + 1}`}
                    class="h-full w-full object-cover opacity-0 transition-opacity duration-300"
                    sizes="(min-width: 640px) 33vw, 50vw"
                    loading="lazy"
                    fetchpriority="low"
                    onload="this.style.opacity='1'; this.closest('[data-img-wrapper]')?.setAttribute('data-loaded','true');"
                  />
                </figure>
              ))}
            </div>
          </div>
        )}
      </div>

      <!-- Footer -->
      <footer class="flex justify-end border-t border-neutral-100 px-5 py-3">
        <button
          type="button"
          class="rounded-full bg-neutral-100 px-5 py-2 text-sm font-semibold text-neutral-700 transition hover:bg-neutral-200 focus:outline-none focus-visible:outline-none"
          data-close
        >
          Lukk
        </button>
      </footer>
    </div>
  </div>
</dialog>

<script is:inline data-dialog-id={id} data-cloud-name={import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME}>
  (function () {
    var script = document.currentScript;
    var dialogId = script?.dataset.dialogId;
    var cloudName = script?.dataset.cloudName || "";
    var dlg = dialogId ? document.getElementById(dialogId) : null;
    if (!dlg) return;

    var closeWithAnim = function () {
      if (!dlg.hasAttribute("open")) return;
      dlg.classList.add("closing");
      setTimeout(function () {
        try { dlg.close(); } catch (_) { dlg.removeAttribute("open"); }
        dlg.classList.remove("closing");
      }, 150);
    };

    dlg.querySelectorAll("[data-close]").forEach(function (b) {
      b.addEventListener("click", function (e) {
        e.preventDefault();
        e.stopPropagation();
        closeWithAnim();
      });
    });

    dlg.addEventListener("cancel", function (e) {
      e.preventDefault();
      closeWithAnim();
    });

    var lightboxEl = null;
    var lightboxKeyHandler = null;

    var teardownLightbox = function () {
      if (lightboxKeyHandler) {
        document.removeEventListener("keydown", lightboxKeyHandler);
        lightboxKeyHandler = null;
      }

      var overlays = Array.from(dlg.querySelectorAll(".lightbox"));
      overlays.forEach(function (overlay) {
        var img = overlay.querySelector(".lightbox__img");
        if (img) {
          img.onload = null;
          img.onerror = null;
          img.removeAttribute("src");
        }
        overlay.remove();
      });

      lightboxEl = null;
    };

    dlg.addEventListener("close", function () {
      var scroller = dlg.querySelector(".gallery-scroll");
      if (scroller) scroller.classList.remove("lightbox-open");
      teardownLightbox();
      document.body.style.overflow = "";
    });

    dlg.addEventListener("click", function (e) {
      var panel = dlg.querySelector(".modal-panel");
      var overlay = dlg.querySelector(".lightbox");
      var t = e.target;
      if (overlay && t instanceof Node && overlay.contains(t)) return;
      if (panel && t instanceof Node && !panel.contains(t)) {
        e.preventDefault();
        closeWithAnim();
      }
    });

    // Gallery items data
    var figures = Array.from(dlg.querySelectorAll("figure[data-gallery-index]"));
    var items = figures.map(function (fig) {
      return {
        src: fig.getAttribute("data-public-id") || "",
        caption: fig.getAttribute("data-caption") || "",
        alt: fig.getAttribute("aria-label") || "",
      };
    });
    var currentIndex = 0;

    var buildUrl = function (publicId) {
      if (!publicId) return "";
      if (/^https?:\/\//.test(publicId)) return publicId;
      if (!cloudName) return "";
      return "https://res.cloudinary.com/" + cloudName + "/image/upload/f_auto,q_auto,w_1200/" + publicId;
    };

    var ensureLightbox = function () {
      // Ensure we never keep stale overlay/listener instances when users spam open/close.
      teardownLightbox();
      var wrap = document.createElement("div");
      wrap.className = "lightbox";
      wrap.innerHTML =
        '<div class="lightbox__frame">' +
          '<button class="lightbox__nav lightbox__nav--prev" aria-label="Forrige bilde">' +
            '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="size-5"><path fill-rule="evenodd" d="M11.78 5.22a.75.75 0 0 1 0 1.06L8.06 10l3.72 3.72a.75.75 0 1 1-1.06 1.06l-4.25-4.25a.75.75 0 0 1 0-1.06l4.25-4.25a.75.75 0 0 1 1.06 0Z" clip-rule="evenodd" /></svg>' +
          '</button>' +
          '<div class="lightbox__col">' +
            '<div class="lightbox__imgwrap">' +
              '<div class="lightbox__skeleton"><div class="lightbox__skeleton-shimmer"></div></div>' +
              '<img class="lightbox__img" alt="" />' +
              '<div class="lightbox__caption"></div>' +
              '<button class="lightbox__close" aria-label="Lukk">' +
                '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="size-5"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 0 1 1.414 0L10 8.586l4.293-4.293a1 1 0 1 1 1.414 1.414L11.414 10l4.293 4.293a1 1 0 0 1-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 0 1-1.414-1.414L8.586 10 4.293 5.707a1 1 0 0 1 0-1.414Z" clip-rule="evenodd" /></svg>' +
              '</button>' +
            '</div>' +
            '<div class="lightbox__counter"></div>' +
          '</div>' +
          '<button class="lightbox__nav lightbox__nav--next" aria-label="Neste bilde">' +
            '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="size-5"><path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" /></svg>' +
          '</button>' +
        '</div>';

      dlg.appendChild(wrap);

      var closeLb = function (e) {
        e.preventDefault();
        e.stopPropagation();
        teardownLightbox();
        var scroller = dlg.querySelector(".gallery-scroll");
        if (scroller) scroller.classList.remove("lightbox-open");
      };

      lightboxKeyHandler = function (e) {
        if (e.key === "Escape") closeLb(e);
        if (e.key === "ArrowLeft") navigate(-1);
        if (e.key === "ArrowRight") navigate(1);
      };

      wrap.addEventListener("click", function (e) {
        e.stopPropagation();
        if (e.target === wrap || e.target.classList.contains("lightbox__frame")) closeLb(e);
      });

      wrap.querySelector(".lightbox__close").addEventListener("click", closeLb);
      wrap.querySelector(".lightbox__nav--prev").addEventListener("click", function (e) {
        e.stopPropagation();
        navigate(-1);
      });
      wrap.querySelector(".lightbox__nav--next").addEventListener("click", function (e) {
        e.stopPropagation();
        navigate(1);
      });

      // Swipe support for mobile
      var touchStartX = 0;
      var touchStartY = 0;
      var touchLocked = false;
      var swipeCol = wrap.querySelector(".lightbox__col");

      wrap.addEventListener("touchstart", function (e) {
        if (e.touches.length === 1) {
          touchStartX = e.touches[0].clientX;
          touchStartY = e.touches[0].clientY;
          touchLocked = false;
          if (swipeCol) {
            swipeCol.style.transition = "none";
            swipeCol.style.willChange = "transform, opacity";
          }
        }
      }, { passive: true });

      wrap.addEventListener("touchmove", function (e) {
        if (e.touches.length !== 1) return;
        var dx = e.touches[0].clientX - touchStartX;
        var dy = e.touches[0].clientY - touchStartY;
        if (!touchLocked && Math.abs(dx) > Math.abs(dy)) {
          touchLocked = true;
        }
        if (touchLocked) {
          e.preventDefault();
          if (swipeCol) {
            var damped = dx * 0.4;
            var opacity = 1 - Math.min(Math.abs(dx) / 300, 0.3);
            swipeCol.style.transform = "translateX(" + damped + "px)";
            swipeCol.style.opacity = opacity;
          }
        }
      }, { passive: false });

      wrap.addEventListener("touchend", function (e) {
        var dx = e.changedTouches[0].clientX - touchStartX;
        var committed = touchLocked && Math.abs(dx) > 40 && items.length > 1;

        if (committed) {
          // Animate out in swipe direction, then navigate
          if (swipeCol) {
            var dir = dx < 0 ? -1 : 1;
            swipeCol.style.transition = "transform 150ms ease-out, opacity 150ms ease-out";
            swipeCol.style.transform = "translateX(" + (dir * 80) + "px)";
            swipeCol.style.opacity = "0";
            setTimeout(function () {
              navigate(dx < 0 ? 1 : -1);
              // Reset and fade in the new image (enter from opposite side)
              swipeCol.style.transition = "none";
              swipeCol.style.transform = "translateX(" + (dir * -60) + "px)";
              swipeCol.style.opacity = "0";
              // Force reflow then animate in
              swipeCol.offsetHeight;
              swipeCol.style.transition = "transform 200ms ease-out, opacity 200ms ease-out";
              swipeCol.style.transform = "";
              swipeCol.style.opacity = "";
              swipeCol.style.willChange = "";
            }, 150);
          }
        } else {
          // Snap back
          if (swipeCol) {
            swipeCol.style.transition = "transform 200ms ease-out, opacity 200ms ease-out";
            swipeCol.style.transform = "";
            swipeCol.style.opacity = "";
            setTimeout(function () { swipeCol.style.willChange = ""; }, 200);
          }
        }
      });

      document.addEventListener("keydown", lightboxKeyHandler);
      lightboxEl = wrap;
      return wrap;
    };

    var navigate = function (dir) {
      if (items.length <= 1) return;
      currentIndex = (currentIndex + dir + items.length) % items.length;
      showImage(currentIndex);
    };

    var sizeSkeleton = function (skeleton, imgwrap, w, h) {
      var maxW = Math.min(window.innerWidth * 0.85, 900);
      var maxH = window.innerHeight * 0.85;
      var scale = Math.min(maxW / w, maxH / h, 1);
      var sw = Math.round(w * scale) + "px";
      var sh = Math.round(h * scale) + "px";
      if (skeleton) {
        skeleton.style.width = sw;
        skeleton.style.height = sh;
        skeleton.style.aspectRatio = "";
      }
      if (imgwrap) {
        imgwrap.style.minWidth = sw;
        imgwrap.style.minHeight = sh;
      }
    };

    var showImage = function (index) {
      if (!lightboxEl) return;
      var item = items[index];
      var img = lightboxEl.querySelector(".lightbox__img");
      var imgwrap = lightboxEl.querySelector(".lightbox__imgwrap");
      var captionEl = lightboxEl.querySelector(".lightbox__caption");
      var skeleton = lightboxEl.querySelector(".lightbox__skeleton");
      var counter = lightboxEl.querySelector(".lightbox__counter");
      var prevBtn = lightboxEl.querySelector(".lightbox__nav--prev");
      var nextBtn = lightboxEl.querySelector(".lightbox__nav--next");
      var url = buildUrl((item.src || "").trim());

      // Size skeleton and wrapper from previous image or default 4:3
      if (img.naturalWidth && img.naturalHeight) {
        sizeSkeleton(skeleton, imgwrap, img.naturalWidth, img.naturalHeight);
      } else {
        sizeSkeleton(skeleton, imgwrap, 800, 600);
      }

      // Show skeleton, hide image
      img.style.opacity = "0";
      if (skeleton) skeleton.style.display = "";

      img.onload = function () {
        img.style.opacity = "1";
        if (skeleton) skeleton.style.display = "none";
        if (imgwrap) { imgwrap.style.minWidth = ""; imgwrap.style.minHeight = ""; }
      };

      img.onerror = function () {
        // Avoid a permanent loading skeleton when a single image URL is invalid.
        if (skeleton) skeleton.style.display = "none";
        img.style.opacity = "0.25";
        if (imgwrap) { imgwrap.style.minWidth = ""; imgwrap.style.minHeight = ""; }
      };

      img.setAttribute("src", url);
      img.setAttribute("alt", item.alt);
      img.setAttribute("draggable", "false");

      if (!url) {
        if (skeleton) skeleton.style.display = "none";
      }

      if (captionEl) {
        captionEl.textContent = item.caption;
        captionEl.style.display = item.caption ? "" : "none";
      }

      if (counter) {
        counter.textContent = (index + 1) + " / " + items.length;
      }

      // Show/hide nav buttons based on item count
      var showNav = items.length > 1;
      if (prevBtn) prevBtn.style.display = showNav ? "" : "none";
      if (nextBtn) nextBtn.style.display = showNav ? "" : "none";
    };

    // Open lightbox on thumbnail click
    figures.forEach(function (fig) {
      fig.addEventListener("click", function (ev) {
        ev.stopPropagation();
        ev.preventDefault();
        var idx = parseInt(fig.getAttribute("data-gallery-index"), 10) || 0;
        currentIndex = idx;
        var overlay = ensureLightbox();
        showImage(currentIndex);
        var scroller = dlg.querySelector(".gallery-scroll");
        if (scroller) scroller.classList.add("lightbox-open");
        overlay.classList.add("is-active");
      });
    });
  })();
</script>

<style is:global>
  dialog.modal {
    touch-action: manipulation;
  }

  dialog.modal::backdrop {
    background: transparent;
  }

  .gallery-scroll {
    position: relative;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .gallery-scroll::-webkit-scrollbar {
    display: none;
  }

  dialog.modal .lightbox {
    position: fixed;
    inset: 0;
    z-index: 80;
    display: grid;
    place-items: center;
    background: rgba(0, 0, 0, 0.92);
    opacity: 0;
    transition: opacity 0.15s ease;
    touch-action: manipulation;
  }
  dialog.modal .lightbox.is-active {
    opacity: 1;
  }

  dialog.modal .lightbox__frame {
    position: relative;
    display: flex;
    align-items: center;
    gap: 1rem;
    max-width: 95vw;
  }

  dialog.modal .lightbox__imgwrap {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  dialog.modal .lightbox__img {
    display: block;
    max-width: min(85vw, 900px);
    max-height: 85vh;
    object-fit: contain;
    border-radius: 12px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
    transition: opacity 200ms ease;
  }

  dialog.modal .lightbox__skeleton {
    position: absolute;
    border-radius: 0.75rem;
    background: rgba(255, 255, 255, 0.08);
    overflow: hidden;
  }

  dialog.modal .lightbox__skeleton-shimmer {
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.06) 50%, transparent 100%);
    animation: modal-shimmer 1.4s ease-in-out infinite;
  }

  @keyframes modal-shimmer {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }

  dialog.modal .lightbox__nav {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 9999px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: white;
    cursor: pointer;
    flex-shrink: 0;
    transition: background 150ms ease, transform 150ms ease;
    touch-action: manipulation;
  }

  dialog.modal .lightbox__nav:hover {
    background: rgba(0, 0, 0, 0.7);
    transform: scale(1.08);
  }

  @media (max-width: 639px) {
    dialog.modal .lightbox__nav {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      z-index: 5;
      width: 2.25rem;
      height: 2.25rem;
    }
    dialog.modal .lightbox__nav:hover {
      transform: translateY(-50%) scale(1.08);
    }
    dialog.modal .lightbox__nav--prev { left: 0.5rem; }
    dialog.modal .lightbox__nav--next { right: 0.5rem; }
  }

  dialog.modal .lightbox__close {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    padding: 0.5rem;
    line-height: 0;
    border: 0;
    border-radius: 9999px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: #fff;
    cursor: pointer;
    outline: none;
  }

  dialog.modal .lightbox__close:hover {
    background: rgba(0, 0, 0, 0.7);
  }

  dialog.modal .lightbox__col {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  dialog.modal .lightbox__caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 2.5rem 1rem 0.8rem;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.6) 0%, transparent 100%);
    color: rgba(255, 255, 255, 0.85);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    pointer-events: none;
    border-radius: 0 0 12px 12px;
  }

  dialog.modal .lightbox__counter {
    margin-top: 0.6rem;
    font-size: 0.7rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.5);
    letter-spacing: 0.1em;
    pointer-events: none;
  }

  .gallery-scroll.lightbox-open {
    overflow: hidden;
  }
</style>
