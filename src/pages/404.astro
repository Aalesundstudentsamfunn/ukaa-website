---
import PageLayout from "../layouts/PageLayout.astro";
import Footer from "../components/Footer.astro";

const title = "Fant ikke siden";
const description = "Den lenken du fulgte finnes ikke. Men vi hjelper deg gjerne tilbake til U.-KA.";
const suggestions = [
  {
    title: "Sjekk programmet",
    detail: "Se oversikten for uka og finn arrangementet du leter etter.",
    href: "/program",
  },
  {
    title: "Kjøp billetter",
    detail: "Gå direkte til billettsiden for arrangementer fra Ålesund Studentsamfunn.",
    href: "https://tikkio.com/organizer/2624-ass-alesund-studentsamfunn",
  },
  {
    title: "Ta kontakt",
    detail: "Send oss en e-post hvis du trenger hjelp med billetter eller info.",
    href: "mailto:ukaa@astudent.no",
  },
];
---

<PageLayout title={title} description={description}>
  <div class="error-page">
    <section class="relative mt-20 sm:mt-24">
      <div class="mx-auto max-w-6xl px-6 pt-10 sm:pt-14">
        <div class="relative overflow-hidden rounded-3xl bg-[#fdbc5b]">
          <div class="error-dot-bg absolute inset-0 pointer-events-none" aria-hidden="true"></div>
          <div class="absolute -top-20 -right-20 h-72 w-72 rounded-full bg-[#f26f7a]/25 blur-3xl pointer-events-none" aria-hidden="true"></div>
          <div class="absolute -bottom-16 -left-16 h-56 w-56 rounded-full bg-[#81c997]/30 blur-3xl pointer-events-none" aria-hidden="true"></div>
          <div class="absolute top-8 left-1/3 h-48 w-48 rounded-full bg-[#84d5f3]/20 blur-3xl pointer-events-none" aria-hidden="true"></div>
          <div class="pointer-events-none absolute inset-3 rounded-2xl border border-white/25" aria-hidden="true"></div>

          <div class="relative px-8 py-16 sm:px-12 sm:py-24 text-center">
            <span class="inline-flex items-center rounded-full bg-[#1b1b1b] px-4 py-1.5 text-xs font-bold uppercase tracking-[0.2em] text-white shadow-sm">404</span>
            <h1 class="mt-5 text-4xl font-extrabold tracking-tight text-[#1b1b1b] leading-[1.1] sm:text-5xl">{title}</h1>
            <p class="mt-4 mx-auto max-w-md text-[#1b1b1b]/60 leading-relaxed text-[0.95rem]">{description}</p>
            <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
              <a href="/" class="error-pill error-pill--solid">Til forsiden</a>
              <a href="/program" class="error-pill error-pill--ghost">Se programmet</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="mx-auto max-w-6xl px-6 pb-20 pt-10 flex-1">
      <div class="error-header">
        <p class="error-header__label">Forslag</p>
        <h2 class="error-header__title">Veien videre</h2>
        <p class="error-header__sub">Her er noen snarveier som ofte løser flokene.</p>
      </div>

      <div class="error-grid">
        {suggestions.map((tip) => (
          <a href={tip.href} target={tip.href.startsWith("http") ? "_blank" : undefined} rel={tip.href.startsWith("http") ? "noreferrer" : undefined} class="error-card">
            <h3>{tip.title}</h3>
            <p>{tip.detail}</p>
            <span class="error-card__link">
              {tip.href.startsWith("mailto:") ? "Send e-post" : "Gå til side"} &rarr;
            </span>
          </a>
        ))}
      </div>
    </div>

    <Footer />
  </div>
</PageLayout>

<style is:global>
  .error-page {
    background: #f7ecd8;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
  }

  .error-dot-bg {
    background-image: radial-gradient(circle, rgba(27, 27, 27, 0.1) 1.5px, transparent 1.5px);
    background-size: 26px 26px;
  }

  .error-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 0.6rem 1.3rem;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    transition: transform 150ms ease, filter 150ms ease, background 150ms ease;
  }

  .error-pill:hover {
    transform: translateY(-1px);
  }

  .error-pill--solid {
    background: #1b1b1b;
    color: white;
  }

  .error-pill--solid:hover {
    filter: brightness(1.08);
  }

  .error-pill--ghost {
    background: rgba(255, 255, 255, 0.5);
    border: 1px solid rgba(27, 27, 27, 0.2);
    color: #1b1b1b;
  }

  .error-pill--ghost:hover {
    background: rgba(255, 255, 255, 0.74);
  }

  .error-header {
    padding-bottom: 1rem;
    border-bottom: 2px solid #fdbc5b;
    margin-bottom: 1.5rem;
  }

  .error-header__label {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.28em;
    font-weight: 700;
    color: #a07830;
  }

  .error-header__title {
    font-size: 2rem;
    font-weight: 800;
    color: #1b1b1b;
    line-height: 1.1;
    margin-top: 0.2rem;
  }

  .error-header__sub {
    margin-top: 0.3rem;
    font-size: 0.875rem;
    color: #7a5e30;
  }

  .error-grid {
    display: grid;
    gap: 1.1rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .error-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .error-card {
    display: flex;
    flex-direction: column;
    border-radius: 1.25rem;
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-top: 3px solid #fdbc5b;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
    padding: 1.3rem;
    text-decoration: none;
    transition: transform 220ms ease, box-shadow 220ms ease;
    cursor: pointer;
  }

  .error-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.08);
  }

  .error-card h3 {
    font-size: 1.1rem;
    font-weight: 800;
    color: #1b1b1b;
    margin-bottom: 0.4rem;
  }

  .error-card p {
    font-size: 0.85rem;
    line-height: 1.6;
    color: #666;
    flex: 1;
  }

  .error-card__link {
    margin-top: 0.75rem;
    font-size: 0.82rem;
    font-weight: 700;
    color: #7f5105;
  }

  .error-card:hover .error-card__link {
    color: #b07508;
  }
</style>
